# Schwab OAuth
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# Webull API
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Active Broker (schwab or webull)
ACTIVE_BROKER=schwab

# AI & News
GEMINI_API_KEY=
TAVILY_API_KEY=

# Reddit API (app-only OAuth - no user login required)
# Register at: https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Security
TOKEN_ENCRYPTION_KEY=                  # Random 32-character string for AES-256 token encryption

# Database
DATABASE_PATH=/var/data/optionsflow.db # Absolute path on VPS

# Optional alerts
ALERT_EMAIL=                           # Email for critical alerts (token expiry, etc.)

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production
PORT=3000

# Reddit API (app-only OAuth — no user login required)
# Register at: https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
